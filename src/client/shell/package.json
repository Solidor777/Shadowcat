{
  "name": "@shadowcat/shell",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@shadowcat/core": "workspace:*",
    "@shadowcat/render": "workspace:*",
    "@shadowcat/types": "workspace:^",
    "@shadowcat/ui-kit": "workspace:*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "e2e:build": "vite build && cargo build -p shadowcat --bin shadowcat",
    "e2e": "pnpm e2e:build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/svelte": "^5.3.1",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0"
  }
}
